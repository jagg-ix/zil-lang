USE NS_CT_CORE_BLOCKER_ISO(f09).
USE NS_CT_CORE_BLOCKER_ISO(f10).
USE NS_CT_CORE_BLOCKER_ISO(f11).
USE NS_CT_CORE_BLOCKER_ISO(f12).
USE NS_CT_CORE_BLOCKER_ISO(f13).
USE NS_CT_CORE_BLOCKER_ISO(f14).
USE NS_CT_CORE_BLOCKER_ISO(f15).
USE NS_CT_CORE_BLOCKER_ISO(f16).
USE NS_CT_CORE_BLOCKER_ISO(f17).
USE NS_CT_CORE_BLOCKER_ISO(f18).
USE NS_CT_CORE_BLOCKER_ISO(f19).
USE NS_CT_CORE_BLOCKER_ISO(f20).
USE NS_CT_CORE_BLOCKER_ISO(f21).
USE NS_CT_CORE_BLOCKER_ISO(f22).
USE NS_CT_CORE_BLOCKER_ISO(f23).

RULE ct_core_blocker_single_class_from_equivalence:
IF ?f#kind@entity:ns_vsnup_equivalent_form AND ?f#equivalent_to@formula:VS_le_nuP
THEN ?f#ct_object_in@entity:ct:vsnup:category:core_blocker_forms AND ?f#ct_iso_class@entity:ct:vsnup:iso_class:core_blocker.

// Blockers: why the route is still not strictly closed in physical semantics.
USE NS_BLOCKER(b01, high, strict_physical_closure_gap, "formal_path_closed_any=true while physical_semantics_closed_any=false on current Path C audit", "MillenniumAuditCertificate.path_C_not_physically_closed", semantic_hardening_gate, "remove remaining load-bearing strict-physical blockers from Path C route").
USE NS_BLOCKER(b02, medium, automation_judge_contract_gap, "judge self-test currently rejects submission (axiom in NSMillenniumClosed and extended L4 manifest mismatch)", "tools/verification/judge-verify.sh", verification_pipeline, "align judge policy/contracts with current theorem graph and submission mode").
USE NS_BLOCKER(b03, high, root_contract_open_bridge, "realNoetherToSliceVS_global_contract remains the single irreducible open root for universal VS<=nu*P", "ThermodynamicRegularityBridge.realNoetherToSliceVS_global_contract", thermodynamic_root_contract, "discharge root contract or replace with constructive non-circular theorem route").
USE NS_BLOCKER(b04, medium, continuation_internalization_gap, "bkm_t3_global_existence remains theorem-level but epistemically bridge-backed in strict closure framing", "BKMBackwardBridge.bkm_t3_global_existence", bkm_internalization, "replace bridge assumptions with deeper internalized continuation derivation").
USE NS_BLOCKER(b05, high, pde_semantics_concretization_gap, "SatisfiesNSPDE and function-space contracts remain in compatibility-layer semantics for strict physical closure", "WORKLOG.ns_target_concretize_pde_semantics_t3", pde_semantics, "tie operators and spaces end-to-end to concrete T3 weak/physical semantics").

// Default metaanalysis classification by form type.
RULE form_meta_default_theorem_iff:
IF ?f#kind@entity:ns_vsnup_equivalent_form AND ?f#form_type@value:theorem_iff
THEN ?f#meta_role@value:equivalence_theorem AND ?f#closure_utility@value:medium AND ?f#load_bearing@value:indirect AND ?f#adds_new_math@value:no AND ?f#physical_readiness@value:depends_on_anchor_route.

RULE form_meta_default_alias:
IF ?f#kind@entity:ns_vsnup_equivalent_form AND ?f#form_type@value:definition_alias
THEN ?f#meta_role@value:naming_alias AND ?f#closure_utility@value:low AND ?f#load_bearing@value:no AND ?f#adds_new_math@value:no AND ?f#physical_readiness@value:symbolic.

RULE form_meta_default_bundle:
IF ?f#kind@entity:ns_vsnup_equivalent_form AND ?f#form_type@value:theorem_equivalence_bundle
THEN ?f#meta_role@value:equivalence_bundle AND ?f#closure_utility@value:medium AND ?f#load_bearing@value:indirect AND ?f#adds_new_math@value:no AND ?f#physical_readiness@value:depends_on_anchor_route.

RULE form_meta_default_canonical:
IF ?f#kind@entity:ns_vsnup_equivalent_form AND ?f#form_type@value:definition_canonical_predicate
THEN ?f#meta_role@value:canonical_target_contract AND ?f#closure_utility@value:high AND ?f#load_bearing@value:target_contract AND ?f#adds_new_math@value:no AND ?f#physical_readiness@value:blocked.

// Targeted overrides for high-value route forms.
USE NS_FORM_META(f03, kernel_monotonicity_gate, high, indirect, no, depends_on_enstrophy_physicalization).
USE NS_FORM_META(f04, projection_to_global_contract, high, indirect, no, depends_on_enstrophy_physicalization).
USE NS_FORM_META(f22, canonical_target_contract, highest, target_contract, no, blocked_by_physical_semantics_gap).
USE NS_FORM_META(f23, root_contract_open_bridge, highest, root_open_bridge, no, open_root).

// Direct blocker links to load-bearing and high-value forms.
USE NS_FORM_BLOCKED_BY(f22, b01).
USE NS_FORM_BLOCKED_BY(f22, b03).
USE NS_FORM_BLOCKED_BY(f22, b04).
USE NS_FORM_BLOCKED_BY(f22, b05).
USE NS_FORM_BLOCKED_BY(f23, b01).
USE NS_FORM_BLOCKED_BY(f23, b03).
USE NS_FORM_BLOCKED_BY(f23, b04).
USE NS_FORM_BLOCKED_BY(f23, b05).
USE NS_FORM_BLOCKED_BY(f03, b05).
USE NS_FORM_BLOCKED_BY(f04, b05).
USE NS_FORM_BLOCKED_BY(f12, b01).
USE NS_FORM_BLOCKED_BY(f14, b01).
USE NS_FORM_BLOCKED_BY(f15, b01).
USE NS_FORM_BLOCKED_BY(f22, b02).
USE NS_FORM_BLOCKED_BY(f23, b02).

// Ranked next-best route to turn equivalence inventory into closure progress.
USE NS_NEXT_ROUTE(1, r01_root_contract, "Discharge or replace realNoether root contract with constructive non-circular route", b03, "theorem-level replacement for realNoetherToSliceVS_global_contract").
USE NS_NEXT_ROUTE(2, r02_strict_physical_audit, "Close strict physical audit after root discharge and semantic hardening", b01, "physical_semantics_closed pathCCertificate = true").
USE NS_NEXT_ROUTE(3, r03_pde_semantics, "Concretize PDE operators and function-space semantics end-to-end", b05, "physical SatisfiesNSPDE + function-space membership on concrete T3 carrier").
USE NS_NEXT_ROUTE(4, r04_bkm_internalization, "Reduce continuation bridge reliance in strict closure framing", b04, "deeper internalized continuation pipeline replacing bridge assumptions").
USE NS_NEXT_ROUTE(5, r05_judge_parity, "Align judge automation contracts with current theorem graph and submission policy", b02, "judge self-test acceptance for intended submission profile").

route:r01_root_contract#advances_form@ns:vsnup:form:f22.
route:r01_root_contract#advances_form@ns:vsnup:form:f23.
route:r02_strict_physical_audit#advances_form@ns:vsnup:form:f22.
route:r03_pde_semantics#advances_form@ns:vsnup:form:f22.
route:r03_pde_semantics#advances_form@ns:vsnup:form:f03.
route:r03_pde_semantics#advances_form@ns:vsnup:form:f04.
route:r04_bkm_internalization#advances_form@ns:vsnup:form:f22.
route:r05_judge_parity#advances_form@ns:vsnup:form:f22.

QUERY forms_catalog:
FIND ?form ?symbol ?form_type ?bridge ?scope ?source_file ?source_line ?first_commit WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#symbol@?symbol AND ?form#form_type@?form_type AND ?form#bridge_layer@?bridge AND ?form#scope@?scope AND ?form#source_file@?source_file AND ?form#source_line@?source_line AND ?form#first_commit@?first_commit.

QUERY forms_with_text:
FIND ?symbol ?equivalence_text WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#symbol@?symbol AND ?form#equivalence_text@?equivalence_text.

QUERY iff_forms:
FIND ?symbol ?bridge WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#form_type@value:theorem_iff AND ?form#symbol@?symbol AND ?form#bridge_layer@?bridge.

QUERY alias_forms:
FIND ?symbol ?bridge WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#form_type@value:definition_alias AND ?form#symbol@?symbol AND ?form#bridge_layer@?bridge.

QUERY global_scope_forms:
FIND ?symbol ?form_type WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#scope@value:global AND ?form#symbol@?symbol AND ?form#form_type@?form_type.

QUERY forms_by_commit:
FIND ?first_commit ?symbol WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#first_commit@?first_commit AND ?form#symbol@?symbol.

QUERY ct_core_blocker_objects:
FIND ?form ?symbol WHERE ?form#ct_object_in@entity:ct:vsnup:category:core_blocker_forms AND ?form#symbol@?symbol.

QUERY ct_core_blocker_iso_class_members:
FIND ?form ?symbol ?iso_class WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#symbol@?symbol AND ?form#ct_iso_class@?iso_class.

QUERY ct_isomorphisms_to_canonical_f22:
FIND ?form ?symbol ?forward ?inverse WHERE ?iso#kind@entity:ct_isomorphism_pair AND ?iso#object@?form AND ?iso#canonical@ns:vsnup:form:f22 AND ?iso#forward@?forward AND ?iso#inverse@?inverse AND ?form#symbol@?symbol.

QUERY blockers_catalog:
FIND ?blocker ?severity ?kind ?statement ?lean_anchor ?owner_lane ?next_step WHERE ?blocker#kind@entity:ns_vsnup_blocker AND ?blocker#severity@?severity AND ?blocker#blocker_kind@?kind AND ?blocker#statement@?statement AND ?blocker#lean_anchor@?lean_anchor AND ?blocker#owner_lane@?owner_lane AND ?blocker#next_step@?next_step.

QUERY blocked_forms_matrix:
FIND ?symbol ?meta_role ?load_bearing ?blocker ?statement WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#symbol@?symbol AND ?form#meta_role@?meta_role AND ?form#load_bearing@?load_bearing AND ?form#closure_blocked_by@?blocker AND ?blocker#statement@?statement.

QUERY why_blocked_summary:
FIND ?blocker ?statement ?lean_anchor WHERE ?blocker#kind@entity:ns_vsnup_blocker AND ?blocker#statement@?statement AND ?blocker#lean_anchor@?lean_anchor.

QUERY load_bearing_forms:
FIND ?symbol ?closure_utility ?physical_readiness WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#load_bearing@value:target_contract AND ?form#symbol@?symbol AND ?form#closure_utility@?closure_utility AND ?form#physical_readiness@?physical_readiness.

QUERY next_best_route:
FIND ?rank ?step ?title ?blocker ?deliverable WHERE ?step#kind@entity:ns_vsnup_next_route_step AND ?step#rank@?rank AND ?step#title@?title AND ?step#discharges_blocker@?blocker AND ?step#deliverable@?deliverable.

QUERY next_route_for_canonical_target:
FIND ?rank ?step ?title WHERE ?step#kind@entity:ns_vsnup_next_route_step AND ?step#rank@?rank AND ?step#title@?title AND ?step#advances_form@ns:vsnup:form:f22.

QUERY route_focus_forms:
FIND ?symbol ?route_role ?route_utility ?route_readiness WHERE ?form#kind@entity:ns_vsnup_equivalent_form AND ?form#symbol@?symbol AND ?form#route_role@?route_role AND ?form#route_closure_utility@?route_utility AND ?form#route_physical_readiness@?route_readiness.
