{
  "schema_version": "0.1",
  "title": "ZIL Benefit Characterization Defaults",
  "score_scale": {
    "min": 1,
    "max": 5,
    "description": "1=low, 5=high"
  },
  "formulas": {
    "raw_benefit_index": "sum(P1..P10) - P11 - P12",
    "adjusted_score": "direction == negative ? (6 - score) : score",
    "weighted_benefit_index": "sum_i(weight_i * adjusted_score_i)",
    "weighted_normalized_score": "weighted_benefit_index / sum(weights)"
  },
  "parameters": [
    {
      "id": "P1",
      "name": "Toolchain Fragmentation",
      "direction": "positive",
      "description": "How many tools and handoffs are needed today"
    },
    {
      "id": "P2",
      "name": "Evidence and Audit Burden",
      "direction": "positive",
      "description": "How strongly the team must justify why decisions are correct"
    },
    {
      "id": "P3",
      "name": "Failure Cost",
      "direction": "positive",
      "description": "Operational, safety, or financial impact when things go wrong"
    },
    {
      "id": "P4",
      "name": "Compliance Pressure",
      "direction": "positive",
      "description": "Regulatory or contractual traceability pressure"
    },
    {
      "id": "P5",
      "name": "Cross-Domain Coupling",
      "direction": "positive",
      "description": "Coupling across software, ops, and physical/business layers"
    },
    {
      "id": "P6",
      "name": "Uncertainty Rate",
      "direction": "positive",
      "description": "How often key information is missing, late, or contradictory"
    },
    {
      "id": "P7",
      "name": "Collaboration Distribution",
      "direction": "positive",
      "description": "How distributed and asynchronous the team or agents are"
    },
    {
      "id": "P8",
      "name": "Manual Glue Burden",
      "direction": "positive",
      "description": "How much custom scripting and spreadsheet/ticket stitching exists"
    },
    {
      "id": "P9",
      "name": "Change Velocity",
      "direction": "positive",
      "description": "How frequently systems, rules, and dependencies change"
    },
    {
      "id": "P10",
      "name": "Formal Maturity Gap",
      "direction": "positive",
      "description": "Lack of in-house formal methods specialists and workflows"
    },
    {
      "id": "P11",
      "name": "Raw Throughput Priority",
      "direction": "negative",
      "description": "Need for extreme runtime throughput over coordination and traceability"
    },
    {
      "id": "P12",
      "name": "Adoption Friction",
      "direction": "negative",
      "description": "Expected resistance and rollout overhead for new modeling workflow"
    }
  ],
